[sub_resource type="GDScript" id="GDScript_lax10"]
script/source = "extends TextureButton


func _on_pressed() -> void:
	# Если окно уже существует
	if WindowManager.select_playlist_window != null and is_instance_valid(WindowManager.select_playlist_window):
		WindowManager.select_playlist_window.show()
		WindowManager.select_playlist_window.grab_focus()
		return

	# Создаем окно
	WindowManager.select_playlist_window = preload(\"res://Windows/SelectPlaylistWindow.tscn\").instantiate()

	get_tree().root.add_child(WindowManager.select_playlist_window)

	WindowManager.select_playlist_window.close_requested.connect(func():
		WindowManager.select_playlist_window.hide()
	)

	WindowManager.select_playlist_window.show()

	TintManager.apply_tint_to_scene()
"

