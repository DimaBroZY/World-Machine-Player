[sub_resource type="GDScript" id="GDScript_kq58d"]
resource_name = "TrackListPanel"
script/source = "extends Control
@onready var track_list_panel: Control = $\".\"



func _on_open_button_pressed() -> void:
	if track_list_panel.visible == true:
		track_list_panel.visible = false
	else:
		track_list_panel.visible = true
"

