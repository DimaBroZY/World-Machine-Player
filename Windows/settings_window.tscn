[sub_resource type="GDScript" id="GDScript_g5yv1"]
resource_name = "notes"
script/source = "extends Panel
# onready var
@onready var label = $ChangeSetting/PanelContainer/Label
@onready var labelText = label.text
# var
var noteEnabled = Settings.get_setting(\"noteEnabled\")

func _ready() -> void:
	noteEnabled = Settings.get_setting(\"noteEnabled\")
	set_label_text()
		
func set_label_text():
	if noteEnabled == false:
		label.text = \"Off\"
	else:
		label.text = \"On\"	
	Settings.save_setting(\"noteEnabled\", noteEnabled)
	
func _on_previous_pressed() -> void:
	noteEnabled = !noteEnabled
	set_label_text()
	EventBus.noteEnabling.emit()
	
func _on_next_pressed() -> void:
	noteEnabled = !noteEnabled
	set_label_text()
	EventBus.noteEnabling.emit()
"

