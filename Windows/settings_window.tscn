[sub_resource type="GDScript" id="GDScript_mcsq1"]
resource_name = "WorldMachineThemeChanger"
script/source = "extends Panel
# onready var
@onready var label = $ChangeSetting/PanelContainer/Label
@onready var labelText = label.text
# var
var worldMachineTheme = Settings.get_setting(\"worldMachineTheme\")



func _ready() -> void:
	if worldMachineTheme == null:
		Settings.save_setting(\"worldMachineTheme\", false)
		worldMachineTheme = Settings.get_setting(\"worldMachineTheme\")
	else:	
		worldMachineTheme = Settings.get_setting(\"worldMachineTheme\")
		set_label_text()
		
func set_label_text():
	if worldMachineTheme == false:
		label.text = \"Off\"
	else:
		label.text = \"On\"	
	Settings.save_setting(\"worldMachineTheme\", worldMachineTheme)
	
func _on_previous_pressed() -> void:
	worldMachineTheme = !worldMachineTheme
	set_label_text()
	EventBus.setWorldMachine.emit()
	
func _on_next_pressed() -> void:
	worldMachineTheme = !worldMachineTheme
	set_label_text()
	EventBus.setWorldMachine.emit()
"

